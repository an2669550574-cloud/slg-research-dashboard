# Root-level .env used by docker-compose.prod.yml
# Copy to .env and fill in real values before `docker compose -f docker-compose.prod.yml up -d`.

# 域名（A 记录指向本机），Caddy 会向 Let's Encrypt 申请证书。
# 本机调试可写 localhost，Caddy 会用本地 CA 自签（仅本机信任）。
SLG_DOMAIN=dashboard.example.com

# Let's Encrypt 通知邮箱；写 internal 时使用本地 CA。
SLG_TLS_EMAIL=ops@example.com

# 自定义 HTTPS 端口；当宿主机 443 已被占用（例如代理面板）时改这里。
# 留空 / 不设 → 默认 443
SLG_HTTPS_PORT=443

# 与 backend/.env 共享的真实凭据；前端构建时也通过 VITE_API_KEY 注入相同值
API_KEY=change-me-to-strong-random-string

# 后端 CORS 白名单，多个值用逗号分隔；通常只列出 SLG_DOMAIN 即可
CORS_ORIGINS=https://dashboard.example.com

# 限流（按 IP 或 API Key），slowapi 表达式
RATE_LIMIT_DEFAULT=120/minute

# 日志级别
LOG_LEVEL=INFO
