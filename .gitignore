frontend/node_modules/
backend/__pycache__/
backend/**/__pycache__/
backend/*.egg-info/
backend/.venv/
backend/venv/

# Build output
frontend/dist/
# TS incremental build cache（机器相关，不应入仓）
*.tsbuildinfo

# Environment & secrets
backend/.env
.env

# Database
backend/*.db
# #232 WAL 模式的 sidecar 文件（本地起 dev server 即产生）
*.db-shm
*.db-wal
backend/*.sqlite
*.db
*.sqlite3

# Logs
*.log

# Backups
backups/
data/

# Caddy state（生产挂载到容器卷，本地不应入仓）
caddy_data/
caddy_config/

# OS
.DS_Store
Thumbs.db

# Claude Code local permissions (machine-specific)
.claude/settings.local.json
# Claude Code runtime lock files
.claude/*.lock
# Claude Code preview launch config (machine-specific local dev server)
.claude/launch.json
# MCP server config — contains absolute paths to local node install
.mcp.json
# Local Playwright MCP node install (machine-specific npm cache/global/modules)
你的安装目录/
