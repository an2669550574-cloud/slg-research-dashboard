# Caddy v2 configuration for SLG Research Dashboard.
#
# Auto HTTPS:
#   - SLG_DOMAIN=example.com → real Let's Encrypt cert
#   - SLG_DOMAIN=localhost   → Caddy local CA (only trusted on this machine)
#
# Custom HTTPS port (when 443 is taken by something else, e.g. a proxy panel):
#   - SLG_HTTPS_PORT=8443 → site served on https://example.com:8443
#                            (port 80 still required for ACME HTTP-01 challenge)
#
# Variables come from docker-compose.prod.yml environment.

{
	email {$SLG_TLS_EMAIL}
}

{$SLG_DOMAIN}:{$SLG_HTTPS_PORT} {
	encode gzip zstd

	# 源站 TLS 策略（env 注入）：留空 = 自动 HTTPS(Let's Encrypt，直连模式，默认)；
	# 置 "tls internal" = 自签证书，供 Cloudflare 橙云前置 + SSL 模式 Full 时用
	# （CF 会拦截 80 端口的 ACME HTTP-01 挑战，源站拿不到 LE 证书，故走自签由 CF 兜公网证书）。
	{$SLG_ORIGIN_TLS}

	# Security headers
	header {
		# Allow images from CDN sources used by iTunes
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		X-Frame-Options DENY
		# 不暴露 Caddy 版本
		-Server
	}

	# API → backend container（FastAPI 路由挂在 /api/*，所以保留前缀，用 handle 而非 handle_path）
	handle /api/* {
		reverse_proxy backend:8000 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# 其它路径都交给前端 nginx 容器（已含 SPA fallback）
	handle {
		reverse_proxy frontend:80
	}
}
