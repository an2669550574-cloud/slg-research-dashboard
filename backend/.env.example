# Sensor Tower API（拿到后填入）
SENSOR_TOWER_API_KEY=your_api_key_here
SENSOR_TOWER_BASE_URL=https://api.sensortower.com

# 太石 LLM 网关（公司统一入口，OpenAI 兼容；钉钉→运维服务平台→AI模型申请 拿 key）
# 视频素材分析 / 未来 AI 历程都走这里，不直连 Anthropic/OpenAI。
TAISHI_API_KEY=your_taishi_key_here
TAISHI_BASE_URL=https://relay.tuyoo.com/v1
TAISHI_VISION_MODEL=claude-sonnet-4.5
TAISHI_TIMEOUT_SECONDS=120

# LLM 日成本软上限（美元）。超出后 /analyze 拒新请求。太石账号本身 $50/天/人。
LLM_DAILY_BUDGET_USD=20.0

# 素材视频分析参数。10 帧是 sonnet 视觉模型的甜区。
MATERIAL_ANALYZE_FRAMES=10
MATERIAL_ANALYZE_FRAME_MAX_DIM=1280

# 旧：直连 Anthropic（已废弃；仅 observability 探活时探测域名解析）。
# 想完全移除，删本字段并删 observability.check_anthropic 引用即可。
ANTHROPIC_API_KEY=

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./slg_research.db

# 是否使用 Mock 数据（无 API key 时设为 true）
USE_MOCK_DATA=true

# API Key 鉴权（生产环境必填；留空则关闭鉴权，仅限本地开发）
API_KEY=

# CORS 白名单：逗号分隔，例如 https://dashboard.example.com,https://staging.example.com
# 留空或填 "*" 表示允许所有来源（仅限本地开发）
CORS_ORIGINS=*

# 日志级别 DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 限流（slowapi 表达式），留空则禁用整体限流；AI 同步独立限制为 10/hour
RATE_LIMIT_DEFAULT=
RATE_LIMIT_AI_SYNC=10/hour

# Sensor Tower 内存级缓存 TTL（秒）。Sensor Tower 自己出的就是 T+1 日级数据，
# 缓存比源头还短就纯属浪费配额。默认 24 小时。
SENSOR_TOWER_CACHE_TTL=86400

# 每月最多调用 Sensor Tower 真实 API 的次数（公司账号配额共享时给本项目留的额度）。
# 超额后自动降级到 sensor_tower_snapshots 表里的最后一次成功响应。
SENSOR_TOWER_MONTHLY_LIMIT=500

# SQLite 持久化快照"新鲜窗口"（小时）。内存 cache miss 时若 SQLite 里
# 已有不超过此时长的快照，直接返回，不消耗月度配额。设成跟 CACHE_TTL 一致即可。
SENSOR_TOWER_SNAPSHOT_FRESH_HOURS=24

# 每日 scheduler 同步的 (country, platform) 组合，逗号分隔。每组每天消耗 1 次
# 月度配额；500/月 ÷ 30 天 ≈ 16 组上限。默认 4 组覆盖 SLG 主要市场。
# 例：US:ios,US:android,JP:ios,KR:ios,GB:ios
SYNC_RANKING_COMBOS=US:ios,US:android,JP:ios,KR:ios

# Sentry 错误上报；留空则不启用
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.05
